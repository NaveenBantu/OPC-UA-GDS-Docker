@page "/"
@page "/dashboard"
@using global::GdsApi
@using System.Net.Http.Headers
@inject IApplicationsGdsApi ApplicationsGdsApi
@inject ICertificateGroupsGdsApi CertificateGroupsGdsApi
@inject ILoginGdsApi LoginGdsApi
@inject IHttpClientFactory HttpClientFactory
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@implements IDisposable

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

<div class="row g-3 mb-4">

    @* Applications card *@
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><strong>Registered Applications</strong></span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="LoadApplications">&#8635; Refresh</button>
            </div>
            <div class="card-body p-0">
                @if (appLoading)
                {
                    <p class="p-3"><em>Loading...</em></p>
                }
                else if (applications.Count == 0)
                {
                    <p class="p-3"><em>No applications registered yet.</em></p>
                }
                else
                {
                    <div style="overflow-x:auto">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Application Name</th>
                                    <th>Id</th>
                                    <th>Type</th>
                                    <th>URI</th>
                                    <th>Product URI</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in applications)
                                {
                                    <tr>
                                        <td><a href="/application/@app.ApplicationId">@app.ApplicationName</a></td>
                                        <td><small>@app.ApplicationId</small></td>
                                        <td>@app.ApplicationType</td>
                                        <td><small>@app.ApplicationUri</small></td>
                                        <td><small>@app.ProductUri</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Auto-Renewal card *@
    <div class="col-12">
        <div class="card">
            <div class="card-header"><strong>Certificate Auto-Renewal</strong></div>
            <div class="card-body">

                <div class="row g-2 align-items-end mb-3">
                    <div class="col-sm-3">
                        <label class="form-label fw-semibold mb-1">Username</label>
                        <input class="form-control form-control-sm" @bind="username" disabled="@isRunning" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label fw-semibold mb-1">Password</label>
                        <input type="password" class="form-control form-control-sm" @bind="password" disabled="@isRunning" />
                    </div>
                    <div class="col-sm-2">
                        <label class="form-label fw-semibold mb-1">Interval (s)</label>
                        <input type="number" class="form-control form-control-sm" @bind="intervalSeconds" min="10" max="3600" disabled="@isRunning" />
                    </div>
                    <div class="col-sm-4">
                        @if (!isRunning)
                        {
                            <button class="btn btn-success btn-sm w-100" @onclick="Start">&#9654; Start Auto-Renewal</button>
                        }
                        else
                        {
                            <button class="btn btn-danger btn-sm w-100" @onclick="Stop">&#9646;&#9646; Stop Auto-Renewal</button>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert @statusClass py-2 mb-2" role="alert">@statusMessage</div>
                }

                @if (log.Count > 0)
                {
                    <div class="border rounded p-2" style="max-height:220px;overflow-y:auto;background:#1e1e1e;color:#d4d4d4;font-family:monospace;font-size:0.82rem">
                        @foreach (var entry in log.AsEnumerable().Reverse())
                        {
                            <div>@entry</div>
                        }
                    </div>
                    <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="() => log.Clear()">Clear log</button>
                }
            </div>
        </div>
    </div>

</div>

@code {

    // ── Applications ─────────────────────────────────────────
    private List<ApplicationApiModel> applications = new();
    private bool appLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadApplications();
    }

    private async Task LoadApplications()
    {
        appLoading = true;
        try
        {
            applications = new List<ApplicationApiModel>(
                await ApplicationsGdsApi.GetApplicationsAllAsync());
        }
        catch (ApiException e)
        {
            if (e.StatusCode != 404) throw;
        }
        finally { appLoading = false; }
    }

    // ── Auto-Renewal ─────────────────────────────────────────
    private string username = "CertificateAuthorityAdmin";
    private string password = "demo";
    private int intervalSeconds = 600;

    private bool isRunning = false;
    private string statusMessage = "";
    private string statusClass = "alert-info";
    private List<string> log = new();
    private CancellationTokenSource? cts;
    private int renewalCount = 0;

    private async Task Start()
    {
        statusMessage = "";
        log.Clear();
        renewalCount = 0;

        try
        {
            var token = await LoginGdsApi.LoginAsync(new LoginApiModel
            {
                UserName = username,
                Password = password
            });
            if (string.IsNullOrEmpty(token))
            {
                SetStatus("Login failed — no token returned.", "alert-danger");
                return;
            }
        }
        catch (Exception ex)
        {
            SetStatus($"Login failed: {ex.Message}", "alert-danger");
            return;
        }

        isRunning = true;
        SetStatus($"Running — renewing every {intervalSeconds}s", "alert-success");
        cts = new CancellationTokenSource();
        _ = RenewLoop(cts.Token);
    }

    private void Stop()
    {
        cts?.Cancel();
        isRunning = false;
        SetStatus($"Stopped after {renewalCount} renewal(s).", "alert-warning");
    }

    private async Task RenewLoop(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            await RenewAll();
            try { await Task.Delay(intervalSeconds * 1000, token); }
            catch (TaskCanceledException) { break; }
        }
    }

    private async Task RenewAll()
    {
        var timestamp = DateTime.Now.ToString("HH:mm:ss");
        try
        {
            var jwt = await LoginGdsApi.LoginAsync(new LoginApiModel
            {
                UserName = username,
                Password = password
            });

            var httpClient = HttpClientFactory.CreateClient("GdsApi");
            httpClient.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", jwt);

            var authedApi = new CertificateGroupsGdsApi(httpClient)
            {
                BaseUrl = Configuration["GdsApi:BaseUrl"] ?? "https://gds-rest:8081"
            };

            var groups = await authedApi.GetCertificateGroupsAsync();
            int succeeded = 0, failed = 0;

            foreach (var group in groups)
            {
                try
                {
                    var newCert = await authedApi.PostCertificateGroupCAAsync((int)group.Id);
                    var expiry = newCert?.NotAfter?.ToString("yyyy-MM-dd HH:mm") ?? "?";
                    AddLog($"[{timestamp}] OK  Group {group.Id} | {newCert?.Subject ?? "renewed"} | expires {expiry}");
                    succeeded++;
                }
                catch (Exception ex)
                {
                    AddLog($"[{timestamp}] ERR Group {group.Id} | {ex.Message}");
                    failed++;
                }
            }

            renewalCount++;
            SetStatus($"Running — renewal #{renewalCount} at {timestamp} ({succeeded} OK, {failed} failed). Next in {intervalSeconds}s.", "alert-success");

            // Also refresh the applications list
            await LoadApplications();
        }
        catch (Exception ex)
        {
            AddLog($"[{timestamp}] ERR renewal #{renewalCount + 1}: {ex.Message}");
            SetStatus($"Error: {ex.Message}", "alert-danger");
        }

        await InvokeAsync(StateHasChanged);
    }

    private void AddLog(string msg) { log.Add(msg); if (log.Count > 200) log.RemoveAt(0); }
    private void SetStatus(string msg, string css) { statusMessage = msg; statusClass = css; }

    public void Dispose() { cts?.Cancel(); cts?.Dispose(); }
}
