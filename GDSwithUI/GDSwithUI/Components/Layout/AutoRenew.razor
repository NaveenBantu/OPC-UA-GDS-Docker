@page "/auto-renew"
@using global::GdsApi
@using System.Net.Http.Headers
@inject ICertificateGroupsGdsApi CertificateGroupsGdsApi
@inject ILoginGdsApi LoginGdsApi
@inject IHttpClientFactory HttpClientFactory
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@implements IDisposable

<PageTitle>Auto Renew</PageTitle>

<h1>Certificate Auto-Renewal</h1>
<p>Automatically regenerate CA certificates on all groups at a set interval. For demo purposes.</p>

<div class="card mb-4" style="max-width:520px">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label fw-semibold">Username</label>
            <input class="form-control" @bind="username" placeholder="CertificateAuthorityAdmin" disabled="@isRunning" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Password</label>
            <input type="password" class="form-control" @bind="password" placeholder="demo" disabled="@isRunning" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Interval (seconds)</label>
            <input type="number" class="form-control" @bind="intervalSeconds" min="10" max="3600" disabled="@isRunning" />
        </div>

        @if (!isRunning)
        {
            <button class="btn btn-success w-100" @onclick="Start">&#9654; Start Auto-Renewal</button>
        }
        else
        {
            <button class="btn btn-danger w-100" @onclick="Stop">&#9646;&#9646; Stop Auto-Renewal</button>
        }
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @statusClass" role="alert">@statusMessage</div>
}

@if (log.Count > 0)
{
    <h5>Renewal Log</h5>
    <div class="border rounded p-2" style="max-height:320px;overflow-y:auto;background:#1e1e1e;color:#d4d4d4;font-family:monospace;font-size:0.85rem">
        @foreach (var entry in log.AsEnumerable().Reverse())
        {
            <div>@entry</div>
        }
    </div>
    <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="() => log.Clear()">Clear log</button>
}

@code {
    private string username = "CertificateAuthorityAdmin";
    private string password = "demo";
    private int intervalSeconds = 600;

    private bool isRunning = false;
    private string statusMessage = "";
    private string statusClass = "alert-info";
    private List<string> log = new();

    private CancellationTokenSource? cts;
    private int renewalCount = 0;

    private async Task Start()
    {
        statusMessage = "";
        log.Clear();
        renewalCount = 0;

        try
        {
            var token = await LoginGdsApi.LoginAsync(new LoginApiModel
            {
                UserName = username,
                Password = password
            });

            if (string.IsNullOrEmpty(token))
            {
                SetStatus("Login failed — no token returned.", "alert-danger");
                return;
            }
        }
        catch (Exception ex)
        {
            SetStatus($"Login failed: {ex.Message}", "alert-danger");
            return;
        }

        isRunning = true;
        SetStatus($"Running — renewing every {intervalSeconds}s", "alert-success");
        cts = new CancellationTokenSource();
        _ = RenewLoop(cts.Token);
    }

    private void Stop()
    {
        cts?.Cancel();
        isRunning = false;
        SetStatus($"Stopped after {renewalCount} renewal(s).", "alert-warning");
    }

    private async Task RenewLoop(CancellationToken token)
    {
        while (!token.IsCancellationRequested)
        {
            await RenewAll();
            try { await Task.Delay(intervalSeconds * 1000, token); }
            catch (TaskCanceledException) { break; }
        }
    }

    private async Task RenewAll()
    {
        var timestamp = DateTime.Now.ToString("HH:mm:ss");

        try
        {
            // Get fresh JWT
            var jwt = await LoginGdsApi.LoginAsync(new LoginApiModel
            {
                UserName = username,
                Password = password
            });

            // Create a one-off HttpClient with the Bearer token set,
            // then wrap it in a CertificateGroupsGdsApi instance.
            // This bypasses the DI-injected client which has no auth header.
            var httpClient = HttpClientFactory.CreateClient("GdsApi");
            httpClient.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", jwt);

            var authedApi = new CertificateGroupsGdsApi(httpClient)
            {
                BaseUrl = Configuration["GdsApi:BaseUrl"] ?? "https://gds-rest:8081"
            };

            var groups = await authedApi.GetCertificateGroupsAsync();
            int succeeded = 0;
            int failed = 0;

            foreach (var group in groups)
            {
                try
                {
                    var newCert = await authedApi.PostCertificateGroupCAAsync((int)group.Id);
                    var expiry = newCert?.NotAfter?.ToString("yyyy-MM-dd HH:mm") ?? "?";
                    AddLog($"[{timestamp}] OK  Group {group.Id} | {newCert?.Subject ?? "renewed"} | expires {expiry}");
                    succeeded++;
                }
                catch (Exception ex)
                {
                    AddLog($"[{timestamp}] ERR Group {group.Id} | {ex.Message}");
                    failed++;
                }
            }

            renewalCount++;
            SetStatus($"Running — renewal #{renewalCount} at {timestamp} ({succeeded} OK, {failed} failed). Next in {intervalSeconds}s.", "alert-success");
        }
        catch (Exception ex)
        {
            AddLog($"[{timestamp}] ERR renewal #{renewalCount + 1}: {ex.Message}");
            SetStatus($"Error: {ex.Message}", "alert-danger");
        }

        await InvokeAsync(StateHasChanged);
    }

    private void AddLog(string message)
    {
        log.Add(message);
        if (log.Count > 200) log.RemoveAt(0);
    }

    private void SetStatus(string message, string cssClass)
    {
        statusMessage = message;
        statusClass = cssClass;
    }

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
    }
}
